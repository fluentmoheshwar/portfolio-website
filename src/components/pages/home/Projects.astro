---
import { Image } from "astro:assets";
import { BiLogoVisualStudio } from "react-icons/bi";
import { FaDownload, FaGithub } from "react-icons/fa6";
import { GoLinkExternal } from "react-icons/go";
import OpenPeriodsImage from "../../../assets/images/home/openperiods.png";
import DSEScraperImage from "../../../assets/images/home/dsescraper.png";
import AmarBanglaBhashaImage from "../../../assets/images/home/amarbanglabhasha.png";
import PujaBloomImage from "../../../assets/images/home/puja_bloom.png";
import TauriWinToolsImage from "../../../assets/images/home/tauriwintools.png";
---

<section class="mx-auto max-w-5xl">
  <h2
    class="mb-3 text-center text-2xl underline decoration-pink-500 sm:text-3xl"
  >
    Projects
  </h2>
  <div class="grid gap-8 sm:grid-cols-2">
    <!-- TauriWinTools Card -->
    <div class="card bg-base-100 shadow-2xl">
      <figure class="px-4 pt-4">
        <Image
          src={TauriWinToolsImage}
          alt="TauriWinTools Screenshot"
          loading="eager"
        />
      </figure>
      <div class="card-body">
        <h2 class="card-title text-xl sm:text-2xl">TauriWinTools</h2>
        <p class="text-justify text-sm sm:text-base">
          It's a collection of handy tools and shortcuts that will make your
          Windows experience more efficient and fun. You can tweak your settings
          or access hidden features with ease.
        </p>
        <div class="card-actions mt-2 flex flex-wrap gap-2">
          <a
            href="https://github.com/fluentmoheshwar/TauriWinTools/releases"
            class="btn btn-primary"
          >
            <FaDownload /> Download
          </a>
          <a
            href="https://github.com/fluentmoheshwar/TauriWinTools"
            class="btn"
          >
            <FaGithub /> GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- Puja Bloom Card -->
    <div class="card bg-base-100 shadow-xl">
      <figure class="px-4 pt-4">
        <Image src={PujaBloomImage} alt="Puja Bloom Theme" />
      </figure>
      <div class="card-body">
        <h2 class="card-title text-xl sm:text-2xl">
          Puja Bloom Visual Studio (Code) Theme
        </h2>
        <p class="text-justify text-sm sm:text-base">
          Puja Bloom is a Visual Studio / Visual Studio Code Theme designed for
          programmers with accessibility and cuteness in mind.
        </p>
        <div class="card-actions mt-2 flex flex-wrap gap-2">
          <a href="https://github.com/fluentmoheshwar/puja-bloom" class="btn">
            <FaGithub /> GitHub
          </a>
          <a
            href="https://marketplace.visualstudio.com/items?itemName=fluentmoheshwar.PujaBloom"
            class="btn bg-violet-700 text-white"
          >
            <BiLogoVisualStudio /> Visual Studio
          </a>
          <a
            href="https://marketplace.visualstudio.com/items?itemName=fluentmoheshwar.puja-bloom"
            class="btn bg-blue-600 text-white"
          >
            <BiLogoVisualStudio /> Visual Studio Code
          </a>
          <a
            href="https://open-vsx.org/extension/fluentmoheshwar/puja-bloom"
            class="btn bg-blue-600 text-white"
          >
            <BiLogoVisualStudio /> OpenVSX
          </a>
        </div>
      </div>
    </div>

    <!-- Open Periods Card -->
    <div class="card bg-base-100 shadow-xl">
      <figure class="px-4 pt-4">
        <Image src={OpenPeriodsImage} alt="OpenPeriods Screenshot" />
      </figure>
      <div class="card-body">
        <h2 class="card-title text-xl sm:text-2xl">OpenPeriods</h2>
        <p class="text-justify text-sm sm:text-base">
          OpenPeriods is a Open Source Browser based Period (menstruation)
          Tracking System for women written in Svelte.
        </p>
        <div class="card-actions mt-2 flex flex-wrap gap-2">
          <a href="https://openperiods.moheshwar.com/" class="btn btn-primary">
            <GoLinkExternal /> Visit
          </a>
          <a href="https://github.com/fluentmoheshwar/openperiods" class="btn">
            <FaGithub /> GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- Amar Bangla Bhasha Card -->
    <div class="card bg-base-100 shadow-xl">
      <figure class="px-4 pt-4">
        <Image
          src={AmarBanglaBhashaImage}
          alt="Amar Bangla Bhasha Screenshot"
        />
      </figure>
      <div class="card-body">
        <h2 class="card-title text-xl sm:text-2xl">Amar Bangla Bhasha</h2>
        <p class="text-justify text-sm sm:text-base">
          Amar Bangla Bhasha is a website that shows the history of the Bengali
          language and its evolution over time. It also provides information
          about the different softwares and tools that are available for
          learning and using the Bengali language.
        </p>
        <div class="card-actions mt-2 flex flex-wrap gap-2">
          <a href="https://bangla.moheshwar.com/" class="btn btn-primary">
            <GoLinkExternal /> Visit
          </a>
          <a
            href="https://github.com/fluentmoheshwar/amarbanglabhasa"
            class="btn"
          >
            <FaGithub /> GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- DSE Scraper Card -->
    <div class="card bg-base-100 shadow-xl">
      <figure class="px-4 pt-4">
        <Image src={DSEScraperImage} alt="DSE Scraper Screenshot" />
      </figure>
      <div class="card-body">
        <h2 class="card-title text-xl sm:text-2xl">DSE Scraper</h2>
        <p class="text-justify text-sm sm:text-base">
          DSE Scraper is a web scraping tool designed to extract data from the
          Dhaka Stock Exchange (DSE) website for analysis and research purposes.
        </p>
        <div class="card-actions mt-2 flex flex-wrap gap-2">
          <a href="https://dsescraper.moheshwar.com/" class="btn btn-primary">
            <GoLinkExternal /> Visit
          </a>
          <a href="https://github.com/fluentmoheshwar/dse-scraper" class="btn">
            <FaGithub /> GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
